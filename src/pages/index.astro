---
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import { siteConfig, homeContent } from "../config/content.ts";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{siteConfig.title}</title>
    <meta name="description" content={siteConfig.description} />
    <script is:inline>
      (function () {
        const savedTheme = localStorage.getItem("theme") || "light";
        const prefersDark = window.matchMedia(
          "(prefers-color-scheme: dark)"
        ).matches;
        const initialTheme =
          savedTheme === "system"
            ? prefersDark
              ? "dark"
              : "light"
            : savedTheme;

        if (initialTheme === "dark") {
          document.documentElement.classList.add("dark");
        } else {
          document.documentElement.classList.remove("dark");
        }
      })();
    </script>
    <script>
      document.addEventListener("DOMContentLoaded", function () {
        window
          .matchMedia("(prefers-color-scheme: dark)")
          .addEventListener("change", (e) => {
            if (localStorage.getItem("theme") === "system") {
              if (e.matches) {
                document.documentElement.classList.add("dark");
              } else {
                document.documentElement.classList.remove("dark");
              }
            }
          });
      });
    </script>
    <style>
      body {
        margin: 0;
        font-family:
          system-ui,
          -apple-system,
          sans-serif;
      }

      /* ---- Hero image ---- */
      .hero-media {
        position: relative;
        z-index: 20;
        width: 40%;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .hero-badge {
        position: relative;
        width: 320px;
        max-width: 80%;
        aspect-ratio: 1 / 1;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 9999px;
        /* neutral frame — matches the site's black/white scheme
           (the previous tech logo used currentColor: black in light,
           white in dark) */
        background: radial-gradient(
          circle at 50% 45%,
          rgba(0, 0, 0, 0.05) 0%,
          rgba(0, 0, 0, 0.025) 55%,
          transparent 72%
        );
        transition: transform 0.35s ease;
      }
      .hero-badge:hover {
        transform: translateY(-4px);
      }

      :global(.dark) .hero-badge {
        background: radial-gradient(
          circle at 50% 45%,
          rgba(255, 255, 255, 0.08) 0%,
          rgba(255, 255, 255, 0.035) 55%,
          transparent 72%
        );
      }

      .hero-img {
        width: 100%;
        height: auto;
        display: block;
      }
      .hero-img--dark {
        display: none;
      }
      :global(.dark) .hero-img--light {
        display: none;
      }
      :global(.dark) .hero-img--dark {
        display: block;
      }

      @media (max-width: 900px) {
        .hero-badge {
          width: 240px;
        }
      }

      .dot-hexagon-light {
        background-image: radial-gradient(
            circle,
            #80808045 1px,
            transparent 1px
          ),
          radial-gradient(circle, #80808045 1px, transparent 1px);
        background-size: 24px 41.57px;
        background-position:
          0 0,
          12px 20.78px;
      }

      .dot-hexagon-dark {
        background-image: radial-gradient(
            circle,
            #ffffff35 1px,
            transparent 1px
          ),
          radial-gradient(circle, #ffffff35 1px, transparent 1px);
        background-size: 24px 41.57px;
        background-position:
          0 0,
          12px 20.78px;
      }
    </style>
  </head>
  <body
    class="min-h-screen flex flex-col bg-white dark:bg-neutral-900 transition-colors duration-300"
  >
    <div class="relative flex-grow flex flex-col">
      <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <div class="absolute inset-0 dot-hexagon-light dark:dot-hexagon-dark">
        </div>
        <div
          class="absolute inset-0 bg-[radial-gradient(ellipse_80%_80%_at_50%_50%,transparent_0%,rgba(255,255,255,0.5)_60%,rgba(255,255,255,0.9)_85%,white_100%)] dark:bg-[radial-gradient(ellipse_80%_80%_at_50%_50%,transparent_0%,rgba(23,23,23,0.5)_60%,rgba(23,23,23,0.9)_85%,rgb(23,23,23)_100%)]"
        >
        </div>
        <div
          class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 h-[1200px] w-[1200px] rounded-full bg-neutral-400 opacity-10 blur-[100px] dark:bg-neutral-600 dark:opacity-15"
          style="max-height: 100vh; max-width: 100vw;"
        >
        </div>
      </div>

      <Navigation />
      <div class="relative flex flex-col flex-1 pt-4 min-h-0">
        <main class="flex-grow flex flex-col min-h-0">
          <div class="flex-1 flex items-center justify-center min-h-0">
            <div
              class="flex flex-row items-center justify-between w-full max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 gap-12"
            >
              <div class="w-[58%] text-left">
                <h1
                  class="text-3xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100 sm:text-4xl"
                >
                  {homeContent.title}
                </h1>
                <div class="mt-3 flex flex-col gap-3">
                  {
                    homeContent.description
                      .split("\n")
                      .map((para) => para.trim())
                      .filter((para) => para.length > 0)
                      .map((para) => (
                        <p class="text-lg leading-8 text-neutral-600 dark:text-neutral-400">
                          {para}
                        </p>
                      ))
                  }
                </div>
                <div class="flex flex-row gap-4 mt-4">
                  <a
                    class="group inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-white bg-neutral-900 rounded-lg hover:bg-neutral-800 dark:bg-neutral-100 dark:text-neutral-900 dark:hover:bg-neutral-200 transition-all duration-300 hover:scale-105 cursor-pointer"
                    href={homeContent.buttons.about.href}
                    >{homeContent.buttons.about.text}<svg
                      class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                      ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2.5"
                        d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg
                    ></a
                  >
                  <a
                    class="group inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-neutral-900 bg-white border border-neutral-300 rounded-lg hover:bg-neutral-50 dark:bg-neutral-800 dark:text-neutral-100 dark:border-neutral-600 dark:hover:bg-neutral-700 transition-all duration-300 hover:scale-105 cursor-pointer"
                    href={homeContent.buttons.posts.href}
                    >{homeContent.buttons.posts.text}<svg
                      class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                      ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2.5"
                        d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg
                    ></a
                  >
                </div>
              </div>
              <div class="hero-media">
                <div class="hero-badge">
                  <img
                    src="/assets/images/hero-light.png"
                    alt="Manali Kaswa"
                    class="hero-img hero-img--light"
                    loading="eager"
                  />
                  <img
                    src="/assets/images/hero-dark.png"
                    alt="Manali Kaswa"
                    class="hero-img hero-img--dark"
                    loading="eager"
                  />
                </div>
              </div>
            </div>
          </div>
        </main>

        <Footer />
      </div>
    </div>
  </body>
</html>
