---
import Navigation from "../../components/Navigation.astro";
import Footer from "../../components/Footer.astro";
import { talksContent } from "../../config/content.ts";

export function getStaticPaths() {
  return talksContent.talks
    .filter((talk) => talk.slides && talk.slides.count > 0)
    .map((talk) => ({
      params: { slug: talk.slug },
      props: { talk },
    }));
}

const { talk } = Astro.props;
const slideNumbers = Array.from({ length: talk.slides.count }, (_, i) => i + 1);
const pad = (n: number) => String(n).padStart(2, "0");
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{talk.title} - Manali Kaswa</title>
    <meta name="description" content={talk.summary} />
    <script is:inline>
      (function () {
        const savedTheme = localStorage.getItem("theme") || "light";
        const prefersDark = window.matchMedia(
          "(prefers-color-scheme: dark)"
        ).matches;
        const initialTheme =
          savedTheme === "system"
            ? prefersDark
              ? "dark"
              : "light"
            : savedTheme;

        if (initialTheme === "dark") {
          document.documentElement.classList.add("dark");
        } else {
          document.documentElement.classList.remove("dark");
        }
      })();
    </script>
    <script>
      document.addEventListener("DOMContentLoaded", function () {
        window
          .matchMedia("(prefers-color-scheme: dark)")
          .addEventListener("change", (e) => {
            if (localStorage.getItem("theme") === "system") {
              if (e.matches) {
                document.documentElement.classList.add("dark");
              } else {
                document.documentElement.classList.remove("dark");
              }
            }
          });
      });
    </script>
    <style>
      html,
      body {
        margin: 0;
        padding: 0;
        min-height: 100%;
        overflow-x: hidden;
      }
      body {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
      }
      main {
        flex: 1;
      }

      .dot-hexagon-light {
        background-image: radial-gradient(
            circle,
            #80808045 1px,
            transparent 1px
          ),
          radial-gradient(circle, #80808045 1px, transparent 1px);
        background-size: 24px 41.57px;
        background-position:
          0 0,
          12px 20.78px;
      }

      .dot-hexagon-dark {
        background-image: radial-gradient(
            circle,
            #ffffff35 1px,
            transparent 1px
          ),
          radial-gradient(circle, #ffffff35 1px, transparent 1px);
        background-size: 24px 41.57px;
        background-position:
          0 0,
          12px 20.78px;
      }

      .slide {
        display: none;
      }
      .slide.active {
        display: flex;
      }
    </style>
  </head>
  <body class="bg-white dark:bg-neutral-900 transition-colors duration-300">
    <div class="fixed inset-0 z-0 pointer-events-none">
      <div
        class="absolute inset-0 -z-10 dot-hexagon-light dark:dot-hexagon-dark"
      >
      </div>
      <div
        class="absolute inset-0 bg-[radial-gradient(ellipse_80%_80%_at_50%_50%,transparent_0%,rgba(255,255,255,0.5)_60%,rgba(255,255,255,0.9)_85%,white_100%)] dark:bg-[radial-gradient(ellipse_80%_80%_at_50%_50%,transparent_0%,rgba(23,23,23,0.5)_60%,rgba(23,23,23,0.9)_85%,rgb(23,23,23)_100%)] -z-10"
      >
      </div>
      <div
        class="absolute left-0 right-0 top-0 -z-10 m-auto h-[1200px] w-[1200px] rounded-full bg-neutral-400 opacity-10 blur-[100px]"
      >
      </div>
    </div>

    <main class="flex-1 relative z-10">
      <Navigation />
      <section class="relative z-20 max-w-4xl mx-auto mt-28 mb-16 px-7 lg:px-0">
        <a
          href="/talks/"
          class="inline-flex items-center gap-1 text-sm text-neutral-500 hover:text-neutral-800 dark:text-neutral-400 dark:hover:text-neutral-100 transition-colors"
        >
          <svg
            class="w-4 h-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
          All talks
        </a>

        <h1
          class="mt-4 text-2xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100 sm:text-3xl lg:text-4xl"
        >
          {talk.title}
        </h1>
        <p class="mt-2 text-sm font-medium text-neutral-500 dark:text-neutral-400">
          {talk.description}
        </p>
        {
          talk.summary && (
            <p class="mt-4 text-sm leading-6 text-neutral-600 dark:text-neutral-400 sm:leading-7 sm:text-base">
              {talk.summary}
            </p>
          )
        }

        {/* Video */}
        <div
          class="relative w-full aspect-video overflow-hidden rounded-xl border border-neutral-200 dark:border-neutral-700 bg-neutral-100 dark:bg-neutral-800 mt-8"
        >
          <iframe
            class="absolute inset-0 w-full h-full"
            src={`https://www.youtube-nocookie.com/embed/${talk.videoId}`}
            title={talk.title}
            loading="lazy"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen></iframe>
        </div>

        {/* Slides carousel */}
        <div class="mt-12 flex items-center justify-between">
          <h2 class="text-xl font-bold dark:text-neutral-200">Slides</h2>
          {
            talk.pdf && (
              <a
                href={talk.pdf}
                target="_blank"
                class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-neutral-900 bg-white border border-neutral-300 rounded-lg hover:bg-neutral-50 dark:bg-neutral-800 dark:text-neutral-100 dark:border-neutral-600 dark:hover:bg-neutral-700 transition-colors"
              >
                <svg
                  class="w-3.5 h-3.5"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5 5-5M12 15V3"
                  />
                </svg>
                Download PDF
              </a>
            )
          }
        </div>

        <div
          id="carousel"
          class="mt-4 rounded-2xl border border-neutral-200 dark:border-neutral-700 bg-neutral-950 overflow-hidden"
        >
          <div class="relative">
            {
              slideNumbers.map((n, i) => (
                <div
                  class:list={["slide items-center justify-center", { active: i === 0 }]}
                  data-index={i}
                >
                  <img
                    src={`${talk.slides.basePath}-${pad(n)}.png`}
                    alt={`${talk.title} — slide ${n}`}
                    class="w-full h-auto"
                    loading={i === 0 ? "eager" : "lazy"}
                    width="1280"
                    height="720"
                  />
                </div>
              ))
            }
          </div>

          {/* Controls */}
          <div
            class="flex items-center justify-between border-t border-neutral-200 dark:border-neutral-700 px-5 py-3 bg-neutral-50/80 dark:bg-neutral-900/60"
          >
            <button
              id="prev"
              class="inline-flex items-center gap-1 px-3 py-1.5 text-sm font-medium rounded-lg text-neutral-700 dark:text-neutral-200 hover:bg-neutral-200 dark:hover:bg-neutral-700 disabled:opacity-40 disabled:cursor-not-allowed transition-colors"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"></path>
              </svg>
              Prev
            </button>
            <span
              id="counter"
              class="text-sm font-medium text-neutral-500 dark:text-neutral-400"
            >
              1 / {talk.slides.count}
            </span>
            <button
              id="next"
              class="inline-flex items-center gap-1 px-3 py-1.5 text-sm font-medium rounded-lg text-neutral-700 dark:text-neutral-200 hover:bg-neutral-200 dark:hover:bg-neutral-700 disabled:opacity-40 disabled:cursor-not-allowed transition-colors"
            >
              Next
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path>
              </svg>
            </button>
          </div>
        </div>
        <p class="mt-3 text-xs text-neutral-400 dark:text-neutral-500">
          Use the arrow keys or the buttons to navigate. {talk.slides.count} slides.
        </p>
      </section>
    </main>

    <Footer />

    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const slides = Array.from(document.querySelectorAll(".slide"));
        const prev = document.getElementById("prev");
        const next = document.getElementById("next");
        const counter = document.getElementById("counter");
        if (!slides.length || !prev || !next || !counter) return;

        let current = 0;
        const total = slides.length;

        function render() {
          slides.forEach((s, i) => s.classList.toggle("active", i === current));
          counter.textContent = `${current + 1} / ${total}`;
          (prev as HTMLButtonElement).disabled = current === 0;
          (next as HTMLButtonElement).disabled = current === total - 1;
        }

        prev.addEventListener("click", () => {
          if (current > 0) current--;
          render();
        });
        next.addEventListener("click", () => {
          if (current < total - 1) current++;
          render();
        });
        document.addEventListener("keydown", (e) => {
          if (e.key === "ArrowLeft" && current > 0) {
            current--;
            render();
          } else if (e.key === "ArrowRight" && current < total - 1) {
            current++;
            render();
          }
        });

        render();
      });
    </script>
  </body>
</html>
